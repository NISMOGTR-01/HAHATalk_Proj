<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:fa6="http://schemas.fontawesome.com/icons/svg">

    <ContextMenu x:Key="SettingContextMenu">
        <MenuItem Header="설정" 
                  Command="{Binding PlacementTarget.DataContext.OpenSettingsCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
                <fa6:SvgAwesome Icon="Solid_Gear" Width="14" PrimaryColor="Black"/>
            </MenuItem.Icon>
        </MenuItem>

        <MenuItem Header="잠금모드" 
                  Command="{Binding PlacementTarget.DataContext.NavigateToLockScreenCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
                <fa6:SvgAwesome Icon="Solid_Lock" Width="14" PrimaryColor="Black"/>
            </MenuItem.Icon>
        </MenuItem>

        <MenuItem Header="잠금모드 암호설정" 
                  Command="{Binding PlacementTarget.DataContext.OpenLockSettingCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
                <fa6:SvgAwesome Icon="Solid_Key" Width="14" PrimaryColor="Black"/>
            </MenuItem.Icon>
        </MenuItem>

        <Separator/>

        <MenuItem Header="로그아웃" 
                  Command="{Binding PlacementTarget.DataContext.LogoutCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
                <fa6:SvgAwesome Icon="Solid_RightFromBracket" Width="14" PrimaryColor="Black"/>
            </MenuItem.Icon>
        </MenuItem>

        <MenuItem Header="종료" 
                  Command="{Binding PlacementTarget.DataContext.ExitCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
            <MenuItem.Icon>
                <fa6:SvgAwesome Icon="Solid_PowerOff" Width="14" PrimaryColor="Black"/>
            </MenuItem.Icon>
        </MenuItem>
    </ContextMenu>

</ResourceDictionary>