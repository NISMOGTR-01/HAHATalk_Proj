<Window x:Class="HAHATalk.Views.SettingsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Views"
             mc:Ignorable="d" 
             Title="설정"
             d:DesignHeight="600" 
             d:DesignWidth="500"
             WindowStartupLocation="CenterOwner"
             Background="White">
    <Grid>
        <!-- Grid.Column 정의 -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="#F9F9F9" BorderBrush="#E0E0E0"
                BorderThickness="0 0 1 0">
            <StackPanel Margin="10 20 0 0">
                <TextBlock Text="설정" FontSize="18"
                           FontWeight="Bold" Margin="10 0 0 20"/>
                <Button Content="계정" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="보안" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="알림" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="친구" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="채팅" Style="{StaticResource MenuButtonStyle}"/>
                <Button Content="백업" Style="{StaticResource MenuButtonStyle}"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="30">
                <TextBlock Text="계정 정보" FontSize="16"
                           FontWeight="Bold" Margin="0 0 0 20"/>

                <Grid Margin="0 0 0 30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Ellipse Width="60" Height="60" 
                             Fill="#D0D0D0"/>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Margin="15 0 0 0">
                        <TextBlock Text="{Binding UserName}"
                                   FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text="{Binding FriendCount, StringFormat='친구 {0}명'}"
                                   Foreground="Gray" FontSize="12"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Right">
                        <Button Content="편집" Style="{StaticResource LinkButtonStyle}"/>
                        <Button Content="친구관리" Style="{StaticResource LinkButtonStyle}"
                                Margin="10 0 0 0"/>
                    </StackPanel>
                </Grid>
                <Separator Background="#F0F0F0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
