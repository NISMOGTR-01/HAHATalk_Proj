<Window x:Class="HAHATalk.Views.ProfileEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="기본프로필 편집" Height="550" Width="380"
        WindowStyle="None" AllowsTransparency="True" 
        Background="Transparent" ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.15" ShadowDepth="1"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="25,20,20,10" Background="Transparent">
                <TextBlock Text="기본프로필 편집" FontSize="18" FontWeight="Bold" Foreground="#333333"/>
                <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0" FontSize="20" Foreground="#999999" 
                        Cursor="Hand" Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"/>
            </Grid>

            <StackPanel Grid.Row="1" Margin="35,30,35,20">

                <Grid HorizontalAlignment="Center" Margin="0,0,0,45">
                    <Ellipse Width="110" Height="110" Stroke="#F0F0F0" StrokeThickness="1">
                        <Ellipse.Fill>
                            <ImageBrush ImageSource="{Binding DisplayProfileImg}" Stretch="UniformToFill"/>
                        </Ellipse.Fill>
                    </Ellipse>

                    <Button Width="36" Height="36" HorizontalAlignment="Right" VerticalAlignment="Bottom"
                            Background="White" BorderBrush="#DDDDDD" BorderThickness="1" Cursor="Hand"
                            Command="{Binding SelectImageCommand}">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}" 
                                        CornerRadius="18">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <Path Data="M4,4H7L9,2H15L17,4H20A2,2 0 0,1 22,6V18A2,2 0 0,1 20,20H4A2,2 0 0,1 2,18V6A2,2 0 0,1 4,4M12,7A5,5 0 0,0 7,12A5,5 0 0,0 12,17A5,5 0 0,0 17,12A5,5 0 0,0 12,7M12,9A3,3 0 0,1 15,12A3,3 0 0,1 12,15A3,3 0 0,1 9,12A3,3 0 0,1 12,9Z" 
                              Fill="#555555" Stretch="Uniform" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <Grid Margin="0,0,0,30">
                    <TextBlock Text="{Binding NameLengthText}" Foreground="#AAAAAA" FontSize="11" 
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-18,0,0"/>

                    <TextBox x:Name="NameInput" 
                             Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="16" Padding="5,10" MaxLength="20" Background="Transparent"
                             BorderThickness="0,0,0,1" BorderBrush="#EEEEEE" Panel.ZIndex="1"/>

                    <TextBlock Text="이름" FontSize="16" Foreground="#CCCCCC" IsHitTestVisible="False"
                               VerticalAlignment="Center" Margin="6,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=NameInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Grid>
                    <TextBlock Text="{Binding StatusLengthText}" Foreground="#AAAAAA" FontSize="11" 
                               HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-18,0,0"/>

                    <TextBox x:Name="StatusInput" 
                             Text="{Binding EditStatus, UpdateSourceTrigger=PropertyChanged}" 
                             FontSize="14" Padding="5,10" MaxLength="60" Background="Transparent"
                             BorderThickness="0,0,0,1" BorderBrush="#EEEEEE" Panel.ZIndex="1"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="60"/>

                    <TextBlock Text="상태메세지" FontSize="14" Foreground="#CCCCCC" IsHitTestVisible="False"
                               VerticalAlignment="Top" Margin="6,10,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=StatusInput}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="2" Margin="25,0,25,30">
                <Button Content="확인" Command="{Binding ConfirmCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="5" Padding="0,14" Background="#FFEB3B" Foreground="#333333"
                        BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button Content="취소" Command="{Binding CloseCommand}"
                        CommandParameter="{Binding RelativeSource={RelativeSource AncestorType=Window}}"
                        Margin="5" Padding="0,14" Background="#F5F5F5" Foreground="#333333"
                        BorderThickness="0" FontSize="15" FontWeight="Bold" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </UniformGrid>
        </Grid>
    </Border>
</Window>