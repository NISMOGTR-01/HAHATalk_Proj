<Window x:Class="HAHATalk.Views.ChatRoomWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Views"
             mc:Ignorable="d" 
             Title="{Binding TargetName}"
             Height="600"
             Width="360"
             Background="#BACEE0"
             WindowStyle="None"
             AllowsTransparency="True"
             >
    <Window.Resources>
        <DataTemplate x:Key="MyMessageTemplate">
            <Grid Margin="10 5" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                    <TextBlock Text="{Binding FormattedTime}" FontSize="10"
                               Foreground="#666666" VerticalAlignment="Bottom"
                               Margin="0 0 5 0"/>

                    <Border Background="#FEE500" CornerRadius="10 0 10 10"
                            Padding="7">
                        <StackPanel>
                            <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                       MaxWidth="200" Foreground="#333333">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MessageType}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Button Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                    CommandParameter="{Binding FilePath}"
                                    Background="Transparent" BorderThickness="0"
                                    Cursor="Hand">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MessageType}" Value="1">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Image Source="{Binding FilePath}" MaxWidth="200"
                                       Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="OtherMessageTemplate">
            <Grid Margin="10 5" HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Width="35" Height="35"
                         VerticalAlignment="Top" Margin="0 0 8 0">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="/Assets/default_profile.jpg"/>                        
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="{Binding SenderName}" FontSize="11"
                               Margin="2 0 0 4" Foreground="#555555"/>
                    <StackPanel Orientation="Horizontal">
                        <Border Background="White" CornerRadius="0 10 10 10"
                                Padding="10 7">
                            <StackPanel>
                                <TextBlock Text="{Binding Message}" TextWrapping="Wrap"
                                            MaxWidth="200" Foreground="#333333">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MessageType}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <Button Command="{Binding DataContext.OpenImageCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding FilePath}"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding MessageTYpe}" Value="1">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                    
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Image Source="{Binding FilePath}" MaxWidth="200"
                                           Stretch="Uniform"/>
                                </Button>                                
                            </StackPanel>                           
                        </Border>
                        <TextBlock Text="{Binding FormattedTime}" FontSize="10"
                                   Foreground="#666666"
                                   VerticalAlignment="Bottom" Margin="5 0 0 0"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="#BACEE0"
              MouseDown="Header_MouseDown">
            <TextBlock Text="{Binding TargetName}"
                       VerticalAlignment="Center" Margin="15 0 0 0"
                       FontSize="16" FontWeight="Bold"
                       Foreground="#333333"/>
            <Button Content="X" HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Width="40" Height="40" 
                    Background="Transparent" BorderBrush="{x:Null}"
                    FontSize="20" Foreground="#555555"
                    Click="CloseButton_Click" 
                    Cursor="Hand"/>
        </Grid>

        <ScrollViewer Grid.Row="1" 
                      x:Name="ChatScroller"
                      VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Messages}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ContentControl Content="{Binding}">
                            <ContentControl.Style>
                                <Style TargetType="ContentControl">
                                    <Setter Property="ContentTemplate" Value="{StaticResource OtherMessageTemplate}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsMine}" Value="True">
                                            <Setter Property="ContentTemplate"
                                                    Value="{StaticResource MyMessageTemplate}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ContentControl.Style>
                        </ContentControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" Padding="5">
            <Grid MinHeight="100">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Command="{Binding SelectFileCommand}"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Bottom"
                        Margin="10 0 0 10"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="파일보내기">
                    <TextBlock Text="&#xE723;"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="20"
                               Foreground="#404040"/>
                    
                </Button>

                <TextBox x:Name="MessageInput"
                         Text="{Binding InputMessage, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         BorderThickness="0" Margin="10 10 10 40"
                         FontSize="14"
                         VerticalScrollBarVisibility="Auto"
                         KeyDown="MessageInput_KeyDown"/>

                <Button Grid.Column="1" Content="전송"
                        Command="{Binding SendMessageCommand}"
                        Background="#FEE500" FontWeight="Bold"
                        Margin="10 10 10 10" Height="40"
                        VerticalAlignment="Bottom">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>


        </Border>
        
        
        
    </Grid>

</Window>
