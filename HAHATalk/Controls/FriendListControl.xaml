<UserControl x:Class="HAHATalk.Controls.FriendListControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Controls"
             xmlns:fa6="http://schemas.fontawesome.com/icons/svg"
             xmlns:vm="clr-namespace:HAHATalk.ViewModels"
             xmlns:libConv="clr-namespace:WPFLib.Converters;assembly=WPFLib"
             mc:Ignorable="d" 
             d:DesignHeight="550" 
             d:DesignWidth="285" 
             Background="white">

    <UserControl.Resources>
        <libConv:IntToVisibilityConverter x:Key="IntToVisibilityConverter"/>

        <Style x:Key="NoSelectionListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="15,10,15,0">
            <TextBlock Text="친구" FontSize="20" FontWeight="Bold" 
                       VerticalAlignment="Center" Margin="5,0,0,0"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Background="Transparent" BorderThickness="0" Cursor="Hand" Margin="0,0,15,0"
                        Command="{Binding SearchCommand}">
                    <fa6:SvgAwesome Icon="Solid_MagnifyingGlass" Width="18" PrimaryColor="#333333"/>
                </Button>

                <Button Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Command="{Binding AddFriendCommand}">
                    <fa6:SvgAwesome Icon="Solid_UserPlus" Width="20" PrimaryColor="#333333"/>
                </Button>
            </StackPanel>
        </Grid>

        <Button Grid.Row="1" 
                Command="{Binding OpenProfileCommand}"
                CommandParameter="{Binding MyProfile}"
                Background="Transparent" BorderThickness="0" Cursor="Hand" 
                HorizontalContentAlignment="Stretch">
            <Grid Margin="20,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Ellipse Width="55" Height="55" VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding MyProfile.ProfileImg, TargetNullValue='/Assets/basic_Profile.png', FallbackValue='/Assets/basic_Profile.png'}" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>

                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="15,0,0,0">
                    <TextBlock Text="{Binding MyProfile.FriendName}" FontWeight="Bold" FontSize="15"/>
                    <TextBlock Text="{Binding MyProfile.StatusMsg}" FontSize="12" Foreground="Gray" 
                               Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Grid>
        </Button>

        <Separator Grid.Row="2" Margin="20,5" Background="#F3F3F3"/>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Hidden">
            <StackPanel Margin="20,10">
                <TextBlock Text="{Binding FriendsCountText}" FontSize="11" Foreground="Gray" Margin="5,0,0,10"/>

                <ItemsControl ItemsSource="{Binding Friends}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12" Background="Transparent" Cursor="Hand">
                                <Grid.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                  Command="{Binding DataContext.OpenProfileCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                  CommandParameter="{Binding}"/>
                                </Grid.InputBindings>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="45"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Ellipse Width="42" Height="42" VerticalAlignment="Center">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding ProfileImg, TargetNullValue='/Assets/basic_Profile.png', FallbackValue='/Assets/basic_Profile.png'}" 
                                    Stretch="UniformToFill"/>
                                    </Ellipse.Fill>
                                </Ellipse>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                                    <TextBlock Text="{Binding FriendName}" FontSize="14" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding StatusMsg}" FontSize="11" Foreground="Gray" 
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>