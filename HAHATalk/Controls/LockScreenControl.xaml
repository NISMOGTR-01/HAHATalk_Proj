<UserControl x:Class="HAHATalk.Controls.LockScreenControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HAHATalk.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="720" d:DesignWidth="450">

    <Grid Background="#FFEB33">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

            <Grid Width="120" Height="120" Margin="0,0,0,15">
                <Ellipse Stroke="#FFFFFF" StrokeThickness="2">
                    <Ellipse.Fill>
                        <ImageBrush ImageSource="{Binding ProfileImage}" Stretch="UniformToFill"/>
                    </Ellipse.Fill>
                </Ellipse>
                <Ellipse Stroke="#000000" StrokeThickness="1" Opacity="0.1"/>
            </Grid>

            <TextBlock Text="{Binding UserEmail}" 
                       HorizontalAlignment="Center" 
                       Foreground="#333333" 
                       FontSize="16" 
                       Margin="0,0,0,40"/>

            <TextBlock Text="잠금모드 상태입니다" 
                       HorizontalAlignment="Center" 
                       FontWeight="Bold" 
                       FontSize="22" 
                       Foreground="#1E1E1E" 
                       Margin="0,0,0,25"/>

            <Grid Width="250" Height="50">
                <PasswordBox x:Name="LockPasswordBox"
                             MaxLength="4"
                             FontSize="24"
                             PasswordChar="●"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Background="White"
                             BorderThickness="0">
                </PasswordBox>
            </Grid>
        </StackPanel>

        <Button Content="잠금모드 암호를 잊었어요" 
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Center" 
                Margin="0,0,0,30"
                Background="Transparent" 
                BorderThickness="0" 
                Foreground="#555555" 
                FontSize="14"
                Cursor="Hand">
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <TextBlock Text="{TemplateBinding Content}" TextDecorations="Underline"/>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>
    </Grid>
</UserControl>