<Application x:Class="HAHATalk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpfConverters="clr-namespace:WPFLib.Converters;assembly=WPFLib"
             xmlns:local="clr-namespace:HAHATalk"
             >
    <Application.Resources>
        
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/Colors.xaml"/>
                <ResourceDictionary Source="/Styles/Buttons.xaml"/>
                <ResourceDictionary Source="/Styles/Fonts.xaml"/>
                <ResourceDictionary Source="/Styles/MainStyles.xaml"/>
            
            </ResourceDictionary.MergedDictionaries>

            <wpfConverters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
            
        </ResourceDictionary>

    </Application.Resources>
</Application>


